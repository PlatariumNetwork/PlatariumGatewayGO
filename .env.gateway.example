# Copy to .env.gateway (gitignored), adjust values, then:
#   set -a && source .env.gateway && set +a
#   pm2 start /absolute/path/to/PlatariumGatewayGO/ecosystem.gateway.config.js
#
# WEBRTC_ICE_SERVERS_JSON must be ONE line (valid JSON array), same shape as Go/Next /api/turn-ice.

PLATARIUM_GATEWAY_CWD=/path/to/platarium-gateway
NODE_HOST=YOUR_PUBLIC_IPV4
# Protocol distribution (% of each block's fee pool; must sum to 100)
PLATARIUM_FAUCET_AMOUNT_PLP=5000
PLATARIUM_FAUCET_COOLDOWN_HOURS=24
PLATARIUM_FAUCET_COOLDOWN_FILE=data/faucet-cooldown.json
PLATARIUM_NETWORK_ID=melancholy-testnet
PLATARIUM_TREASURY_PCT=18
PLATARIUM_L1_PCT=36
PLATARIUM_L2_PCT=36

# Auto L1/L2 on testnet (default: enabled with --testnet). L1 when mempool non-empty; L2 when pending block exists.
# PLATARIUM_AUTO_BLOCK=true
# PLATARIUM_AUTO_BLOCK_L1_INTERVAL_SEC=5
# PLATARIUM_AUTO_BLOCK_L2_INTERVAL_SEC=30

# Optional overrides (defaults: 1812/1813 and 1822/1823)
# GATEWAY01_REST_PORT=1812
# GATEWAY01_WS_PORT=1813
# GATEWAY02_REST_PORT=1822
# GATEWAY02_WS_PORT=1823

WEBRTC_ICE_SERVERS_JSON=[{"urls":"stun:YOUR_PUBLIC_IPV4:3478"},{"urls":"turn:YOUR_PUBLIC_IPV4:3478?transport=udp","username":"YOUR_TURN_USER","credential":"YOUR_TURN_PASS"},{"urls":"turn:YOUR_PUBLIC_IPV4:3478?transport=tcp","username":"YOUR_TURN_USER","credential":"YOUR_TURN_PASS"}]
